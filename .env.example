# Open Forest Sentinel configuration. Copy to `.env` and fill in.
# `.env` is gitignored — never commit real credentials.

# --- Database (read by forest_sentinel.db) ---
# Defaults to the local docker compose instance if unset.
FOREST_SENTINEL_DATABASE_URL=postgresql+psycopg://forest_sentinel:forest_sentinel@localhost:5432/forest_sentinel

# --- Earth Engine + Cloud Storage (read by forest_sentinel.earthengine / .storage) ---
# Required for the optical-change pipeline (the windowed `--since/--until` run).
# EE-registered GCP project id (or pass --gee-project on the CLI):
FOREST_SENTINEL_GEE_PROJECT=your-gcp-project-id
# Transient GCS bucket Earth Engine exports COGs into (created by scripts/setup_gcp.sh):
FOREST_SENTINEL_GCS_STAGING_BUCKET=your-gcp-project-id-ofs-staging
# Local canonical COG directory (gitignored; on the VM use /data/cogs):
FOREST_SENTINEL_COG_ROOT=data/cogs/
# Credentials are ambient (Application Default Credentials): on the VM they come
# from the attached service account's metadata server; locally run
# `gcloud auth application-default login`. Only uncomment this for key-based
# local development (mint a key with `CREATE_KEY=1 scripts/setup_gcp.sh`) —
# a path pointing at a missing file makes ADC fail instead of falling back.
# GOOGLE_APPLICATION_CREDENTIALS=./gcp-service-account.json

# --- Scheduled run (read by scripts/run_pipeline.sh) ---
# AOI to process and the size of the rolling window in days.
AOI_PATH=examples/aoi-sample.geojson
# Directory of additional AOI GeoJSONs: every *.geojson here runs sequentially
# alongside AOI_PATH. Dashboard uploads land here too (also read by the
# dashboard; set FOREST_SENTINEL_AOI_UPLOADS=0 to disable uploads).
FOREST_SENTINEL_AOIS_DIR=aois
WINDOW_DAYS=30
# Optional pipeline tuning passthroughs (leave blank to use the CLI defaults:
# THRESHOLD=-0.25, MIN_AREA=4500 m^2, BASELINE_WINDOW=5).
# WARNING: these are methodology inputs — changing them mints a new methodology
# version on the next run and re-exports the whole window (see
# config/instance.env for the full note).
BASELINE_WINDOW=
THRESHOLD=
MIN_AREA=
