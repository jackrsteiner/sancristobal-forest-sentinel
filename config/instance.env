# Open Forest Sentinel — per-instance configuration. COMMITTED to the instance
# repo (nothing here is a secret) and read by both the "Deploy instance" GitHub
# Action (gcloud arguments) and scripts/vm_setup.sh (app settings on the VM).
#
# Instance repos: set PROJECT_ID (required) and replace config/aoi.geojson with
# your own AOI (build one at https://jackrsteiner.github.io/aoi-maker/), then
# commit. See INSTANCE_DEPLOYMENT.md for the full workflow.

# --- Google Cloud (read by setup_gcp.sh / provision_vm.sh / teardown_gcp.sh) ---
# GCP project id, billing-enabled and registered for Earth Engine (required):
PROJECT_ID=
# Bucket location and VM zone. The always-free e2-micro tier is only free in
# us-west1 / us-central1 / us-east1.
REGION=us-west1
ZONE=us-west1-a
INSTANCE_NAME=forest-sentinel-vm
# Staging bucket name (blank = ${PROJECT_ID}-ofs-staging):
STAGING_BUCKET=

# --- App image (read by scripts/vm_setup.sh and the systemd wrappers) ---
# Opt-in container mode (#96): run the pipeline, dashboard, and prune job from
# the CI-published image instead of building from source with uv on the VM.
# Blank (the default) keeps the from-source path. Example:
#   APP_IMAGE=ghcr.io/jackrsteiner/open-forest-sentinel:latest
# Pin a commit-SHA tag instead of latest for a fully reproducible instance.
# After changing, re-run scripts/vm_setup.sh (or the Update instance workflow).
APP_IMAGE=

# --- Dashboard ---
DASHBOARD_PORT=8000
# Set to 1 to open DASHBOARD_PORT to the internet (default: SSH tunnel only):
OPEN_DASHBOARD=0

# --- Scheduled pipeline run (read by scripts/run_pipeline.sh via .env) ---
WINDOW_DAYS=30
# systemd budget for one run. Runs checkpoint per observation and resume, so a
# timeout mid-backfill just continues at the next timer firing:
PIPELINE_TIMEOUT=20h
# Earth Engine batch exports kept in flight at once (higher = faster runs, up to
# your EE noncommercial tier's concurrency limit; see docs/scaling.md):
FOREST_SENTINEL_MAX_CONCURRENT_EXPORTS=4
# Days without a new detection before an ongoing event auto-resolves (needs at
# least one sufficiently clear later observation — a cloudy gap alone never
# resolves an event). Lifecycle config, NOT a methodology input: changing it
# does not mint a new methodology version. Blank = the default (90):
RESOLVED_AFTER_DAYS=90
# Meters to search for "nearby" context features (concessions, roads, rivers,
# mills, ... loaded from config/context/) around each event; the nearest
# feature per layer kind within the buffer is recorded and shown per event.
# Lifecycle config, NOT a methodology input. Blank = the default (5000):
CONTEXT_BUFFER_M=
# Days of exported COGs to keep on the VM disk (blank/0 = keep forever). Applied
# daily by the forest-sentinel-prune timer; smaller = more monitored area per
# disk (docs/scaling.md). Never prunes inside WINDOW_DAYS + a safety margin, and
# never touches database rows — a pruned raster is re-exported on demand:
COG_RETENTION_DAYS=90
# Optional pipeline tuning passthroughs (leave blank to use the CLI defaults:
# THRESHOLD=-0.25 — flag pixels whose NBR dropped >= 0.25 vs the trailing-median
# baseline, roughly "moderate-severity burn or outright clearing"; MIN_AREA=4500
# m^2 (0.45 ha, ~5 HLS pixels); BASELINE_WINDOW=5 prior observations).
#
# WARNING: these are methodology inputs. Changing any of them makes the next run
# mint a NEW methodology version (provenance is content-addressed), and nothing
# computed under the old parameters is reusable — the run re-exports the whole
# window from Earth Engine (hours of queue time + EE quota). Reverting to a
# previously used parameter set re-matches that version, and its artifacts are
# reused again. The dashboard run card shows which methodology each run used.
BASELINE_WINDOW=
THRESHOLD=
MIN_AREA=
# Forest mask (also a methodology input — same WARNING applies). Candidates are
# only extracted on forested pixels, so crop harvests / grassland change never
# reach the events table (docs/architecture.md §5.7). Sources: hansen (default —
# Hansen Global Forest Change, canopy % >= FOREST_MASK_CANOPY_PCT minus already-
# lost pixels), worldcover (ESA WorldCover tree-cover class), none (disable
# masking, e.g. for non-forest use cases). Leave blank for the defaults.
FOREST_SENTINEL_FOREST_MASK=
FOREST_SENTINEL_FOREST_MASK_ASSET=
FOREST_SENTINEL_FOREST_MASK_CANOPY_PCT=
# Radar augmentation (Slice 5): set to 1 to also run Sentinel-1 GRD backscatter
# change (VV dB drop vs same-orbit trailing median) under its own radar-change
# methodology — a separate detection lineage alongside the optical one. Radar
# sees through clouds; expect extra Earth Engine exports per run. The threshold
# is a methodology input (same re-export WARNING as above; blank = -3.0 dB):
FOREST_SENTINEL_RADAR=0
FOREST_SENTINEL_RADAR_THRESHOLD=
# Near-real-time repo sync of dashboard changes (Slice 7 bead 7.3). When both
# are set, a settings edit or AOI/context upload fires the Update-instance
# workflow's sync jobs via workflow_dispatch, committing the change to this
# repo within about a minute. Leave blank to keep today's behavior (changes
# stay VM-local until the workflow is run manually).
#   GITHUB_REPO: this instance repo as owner/name.
#   FOREST_SENTINEL_SYNC_TOKEN_FILE: absolute path to a mode-0600 file on the
#   VM holding a fine-grained PAT scoped to THIS repo only with
#   "Actions: read and write" — and no other permission. Do NOT use a
#   contents-write or classic token; see INSTANCE_DEPLOYMENT.md.
GITHUB_REPO=
FOREST_SENTINEL_SYNC_TOKEN_FILE=
# Seconds to wait for one Earth Engine export before giving up (blank = 3600).
# Robustness tuning only; a timed-out export is retried on the next run.
FOREST_SENTINEL_EXPORT_TIMEOUT_SECONDS=
# Timer schedules (UTC; blank = pipeline 03:00:00, prune 02:30:00). A time of
# day (HH:MM[:SS], runs daily) or a systemd shorthand (hourly/daily/weekly);
# expressions with date parts need a hand edit of scripts/systemd/*.timer.
# Rendered into the systemd timers by vm_setup.sh, so changes roll out on the
# next Update-instance run. Keep the prune before the pipeline schedule.
PIPELINE_SCHEDULE=
PRUNE_SCHEDULE=
